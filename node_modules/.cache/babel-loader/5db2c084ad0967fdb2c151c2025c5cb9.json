A,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,yDAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAZA,EAiBA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,oCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAjBA,CALA;AA4BA,UAAA,gBAAA,EAAA,sCA5BA;AA6BA,UAAA,kBAAA,EAAA;AA7BA,SA5FA,EA2HA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,oEAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,8CAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EACA,oEAHA;AAIA,YAAA,UAAA,EAAA;AAJA,WANA,EAYA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,0DAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAZA,EAiBA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,2BAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAjBA,CALA;AAwBA,UAAA,gBAAA,EAAA,sCAxBA;AAyBA,UAAA,kBAAA,EAAA;AAzBA,SA3HA,CANA;AA6JA,QAAA,sBAAA,EAAA,uCA7JA;AA8JA,QAAA,uBAAA,EACA;AA/JA;AADA,KAAA;AAAA;AALA,CAAA","sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n\n<script>\nimport Actividad from '@/components/actividad/Actividad.vue'\nexport default {\n  name: 'ActividadDidactica',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Fundamentos de Ingeniería',\n      titulo: 'Cuestionario',\n      introduccion:\n        '<b>Objetivo:</b> Comprender los conceptos fundamentales de la ingeniería y su diferenciación con otras disciplinas.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            '¿Cuál de las siguientes opciones mejor describe la ingeniería?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Una ciencia exacta que se basa únicamente en cálculos',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto:\n                'Una disciplina que combina conocimientos teóricos y prácticos',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'Una actividad artística que se enfoca en la creatividad',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Una profesión que solo se ocupa de construir edificios',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 2,\n          texto: '¿Qué papel juega la creatividad en la ingeniería?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Es una habilidad poco importante',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Es esencial para encontrar soluciones innovadoras',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'Solo es útil en ciertas áreas de la ingeniería',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Se contrapone al pensamiento lógico',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 3,\n          texto: '¿Qué significa pensar como un ingeniero?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto:\n                'Ser capaz de resolver problemas de manera lógica y sistemática',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Tener una gran capacidad para memorizar fórmulas',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto:\n                'Ser experto en el uso de software de diseño asistido por computadora',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Ser capaz de trabajar solo sin la ayuda de otros',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 4,\n          texto:\n            'La principal diferencia entre un científico y un ingeniero es que:',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'El científico descubre y el ingeniero aplica',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto:\n                'El científico trabaja en un laboratorio y el ingeniero en una obra',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'El científico es más creativo y el ingeniero más lógico',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'ambos cumplen las mismas funciones',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 5,\n          texto:\n            'La principal diferencia entre un científico y un ingeniero es que:',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'El científico descubre y el ingeniero aplica',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto:\n                'El científico trabaja en un laboratorio y el ingeniero en el campo',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'El científico es más teórico y el ingeniero más práctico',\n              esCorrecta: false,\n            },\n            { id: 'd', texto: 'tienen muchas diferencias', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"],"sourceRoot":"src/views"}]}